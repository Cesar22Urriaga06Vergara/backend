# Servidor
PORT=3001
NODE_ENV=development
ENABLE_SWAGGER=true
FRONTEND_URL=http://localhost:3000

# Base de datos MySQL
# En Railway, si agregas un servicio MySQL, usa preferiblemente MYSQL_URL.
MYSQL_URL=
MYSQLHOST=
MYSQLPORT=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=tu_password_aqui
DB_DATABASE=hotel
TYPEORM_SYNCHRONIZE=false
TYPEORM_LOGGING=false

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_unico
JWT_EXPIRATION=1h

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER_NAME=imghotel

# CORS: separar multiples origenes con coma
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# IPC DANE parametrizable. Actualizar desde fuente oficial DANE antes de aplicar reajustes.
DANE_IPC_ANNUAL_PERCENT=
DANE_IPC_REFERENCE_PERIOD=
DANE_IPC_SOURCE_URL=https://www.dane.gov.co/index.php/estadisticas-por-tema/precios-y-costos/indice-de-precios-al-consumidor-ipc
DANE_IPC_UPDATED_AT=

# Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Scripts de migracion/seed
SEED_DEFAULT_PASSWORD=cambia_esta_password_para_entornos_no_locales
